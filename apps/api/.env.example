# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# PostgreSQL
DATABASE_URL=postgresql://twon:twon_dev@localhost:5432/twon_db

# MongoDB
MONGODB_URI=mongodb://twon:twon_dev@localhost:27017/twon?authSource=admin

# Redis (local docker)
REDIS_URL=redis://localhost:6379
# Redis (Upstash — staging/production)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=twon-storage
R2_PUBLIC_DOMAIN=

# Email — Resend
RESEND_API_KEY=re_test_xxxx
EMAIL_FROM=noreply@yourdomain.com

# Payment — Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Payment — Omise (PromptPay)
OMISE_PUBLIC_KEY=pkey_test_xxxx
OMISE_SECRET_KEY=skey_test_xxxx

# Sentry (optional)
SENTRY_DSN=
